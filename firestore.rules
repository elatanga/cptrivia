
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- CUSTOM AUTH ARCHITECTURE NOTES ---
    // This app uses a custom username/token system stored in the 'users' collection.
    // It does NOT use standard Firebase Auth for user management.
    // Therefore, request.auth.uid will usually be null or anonymous.
    // Writes are primarily handled via Cloud Functions (Admin SDK).

    // 1. TOKEN REQUESTS
    // All reads/writes must flow through Cloud Functions so request review and notification state stay authoritative.
    match /token_requests/{requestId} {
      allow read, create, update, delete: if false;
    }

    // 2. USERS
        // allows the creation of the very first admin user during bootstrap
        match /users/{userId} {
          allow create: if userId == 'admin' &&
            get(/databases/$(database)/documents/system_bootstrap/config).data.initialized == false;
          allow read, update, delete: if false;
        }

   // 3. SYSTEM BOOTSTRAP
       // allows the frontend to check status and perform the initial one-time setup
       match /system_bootstrap/config {
         allow read: if true;
         allow create: if request.resource.data.initialized == false;
         allow update: if resource.data.initialized == false;
       }

    match /system_bootstrap/recovery {
      allow read, write: if false;
    }
    
    // 4. AUDIT LOGS
    // Audit writes/reads must be server-side to preserve integrity.
    match /audit_logs/{logId} {
      allow read, create, update, delete: if false;
    }

    match /studio_sessions/{sessionId} {
      allow read, write: if false;
    }
  }
}
